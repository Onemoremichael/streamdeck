{
  "name": "codex-attention-stream-deck",
  "version": "0.4.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "rollup -c",
    "test": "tsx --test test/*.test.js",
    "typecheck": "tsc --noEmit",
    "validate": "streamdeck validate com.onemoremichael.codex-attention.sdPlugin",
    "pack": "streamdeck pack --force com.onemoremichael.codex-attention.sdPlugin",
    "install:claude-hooks": "node scripts/install-claude-hooks.mjs"
  },
  "dependencies": {
    "@elgato/streamdeck": "latest"
  },
  "devDependencies": {
    "@elgato/cli": "latest",
    "@rollup/plugin-commonjs": "latest",
    "@rollup/plugin-node-resolve": "latest",
    "@rollup/plugin-typescript": "latest",
    "@types/node": "latest",
    "rollup": "latest",
    "tslib": "latest",
    "tsx": "latest",
    "typescript": "5.9.3"
  }
}
